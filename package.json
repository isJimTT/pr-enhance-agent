{
  "name": "pr-enhance-agent",
  "version": "1.0.0",
  "description": "Configurable Gitee webhook bot that analyzes PRs and updates docs via LLM",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "dotenv": "^17.4.2",
    "hono": "^4.6.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.73.0",
    "pg": "^8.21.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "simple-git": "^3.27.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
