# Server
PORT=8787
BOT_CONFIG=./config/bot.yaml

# Workspace for git repos
WORKSPACE_ROOT=./workspace

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/pr_enhance_agent

# Gitee
GITEE_TOKEN=your_gitee_personal_access_token
GITEE_WEBHOOK_SECRET=your_webhook_secret
GITEE_REPO=owner/repo-name

# DeepSeek (for LLM strategy)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
